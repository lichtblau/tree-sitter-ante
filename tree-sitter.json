{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "ante",
      "camelcase": "Ante",
      "title": "Ante",
      "scope": "source.ante",
      "file-types": [
        "an"
      ],
      "injection-regex": "^ante$",
      "class-name": "TreeSitterAnte"
    }
  ],
  "metadata": {
    "version": "0.0.1",
    "license": "MIT",
    "description": "Ante grammar for tree-sitter",
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-ante"
    }
  },
  "bindings": {
    "c": true,
    "go": false,
    "node": true,
    "python": false,
    "rust": true,
    "swift": false,
    "zig": false
  }
}
